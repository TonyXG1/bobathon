# Regulatory Radar - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE
# ============================================================================

# Database connection URL
# SQLite (default for development):
DATABASE_URL=sqlite:///./regulatory_radar.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/regulatory_radar

# ============================================================================
# CELLAR / EUR-Lex Configuration
# ============================================================================

# CELLAR SPARQL endpoint for metadata queries
CELLAR_SPARQL_ENDPOINT=http://publications.europa.eu/webapi/rdf/sparql

# CELLAR REST API base URL for Formex XML retrieval
CELLAR_REST_BASE_URL=https://eur-lex.europa.eu/legal-content/EN/TXT/

# Maximum concurrent connections to CELLAR (keep < 5 to avoid rate limiting)
CELLAR_MAX_CONNECTIONS=5

# Request timeout in seconds for CELLAR
CELLAR_TIMEOUT=60

# Number of results per SPARQL query page (use LIMIT/OFFSET pagination)
CELLAR_PAGE_SIZE=100

# ============================================================================
# ECHA Configuration
# ============================================================================

# ECHA SVHC Candidate List URL
ECHA_CANDIDATE_LIST_URL=https://echa.europa.eu/candidate-list-table

# Cache TTL for ECHA data in hours (24h recommended)
ECHA_CACHE_TTL_HOURS=24

# Request timeout in seconds for ECHA
ECHA_TIMEOUT=30

# ============================================================================
# HTTP Client Configuration
# ============================================================================

# User-Agent header for polite client behavior
# IMPORTANT: Include contact information
USER_AGENT=RegulatoryRadar/1.0 (contact: your-email@example.com)

# Maximum number of retries for failed requests
MAX_RETRIES=3

# Exponential backoff factor for retries (wait = factor ^ attempt)
RETRY_BACKOFF_FACTOR=2.0

# ============================================================================
# Taxonomy Configuration
# ============================================================================

# Path to taxonomy.json file (relative to repo root)
TAXONOMY_PATH=dataset/taxonomy.json

# ============================================================================
# Feature Flags
# ============================================================================

# Enable CELLAR SPARQL discovery
ENABLE_CELLAR_SPARQL=true

# Enable ECHA SVHC list fetching
ENABLE_ECHA_FETCH=true

# ============================================================================
# API Configuration (Extraction Service)
# ============================================================================

# API server host
API_HOST=0.0.0.0

# API server port
API_PORT=8081

# Allowed CORS origins (comma-separated or JSON array)
CORS_ORIGINS=["http://localhost:8501", "http://localhost:5173"]

# ============================================================================
# Logging Configuration
# ============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# Twilio Configuration (Alerting Service)
# ============================================================================

# Twilio Account SID
TWILIO_ACCOUNT_SID=your_account_sid_here

# Twilio Auth Token
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio phone number (for SMS/WhatsApp)
TWILIO_FROM_NUMBER=+1234567890

# Test recipient number (YOUR OWN NUMBER for testing)
# IMPORTANT: Never send alerts to portfolio contacts (they are synthetic)
TWILIO_TEST_NUMBER=+1234567890

# Test recipient email (YOUR OWN EMAIL for testing)
TWILIO_TEST_EMAIL=your-email@example.com

# ============================================================================
# IBM Bob Configuration (Optional)
# ============================================================================

# IBM Bob API key (if using Bob for development)
# IBM_BOB_API_KEY=your_api_key_here

# ============================================================================
# NOTES
# ============================================================================

# Security:
# - Never commit .env to version control (it's in .gitignore)
# - Rotate secrets regularly
# - Use different secrets for dev/staging/prod
# - Store production secrets in a secret manager (AWS Secrets Manager, etc.)

# Twilio Promo Code:
# - Use code "TUM-TWILIO-50" for hackathon credit

# Rate Limiting:
# - CELLAR: Keep < 5 concurrent connections, use exponential backoff
# - ECHA: Cache for 24h, send clear User-Agent with contact

# Database:
# - SQLite is fine for demo/dev
# - Use PostgreSQL for production
# - Schema is compatible with both