# ============================================================================
# Regulatory Radar — environment template
# Copy to .env (gitignored). All variables are optional: without Twilio/
# SendGrid credentials the alerting service SIMULATES sends, so the pipeline
# still works end-to-end.
# ============================================================================

# ---------------------------------------------------------------------------
# TWILIO (SMS / WhatsApp) — https://console.twilio.com/
# Auth is either ACCOUNT_SID + AUTH_TOKEN, or ACCOUNT_SID + API key pair.
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# TWILIO_API_KEY_SID=SK...
# TWILIO_API_SECRET=

# Your Twilio number (the SMS "from")
TWILIO_PHONE_NUMBER=
# WhatsApp sender (defaults to the Twilio sandbox)
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# OUR OWN test recipients — never portfolio contacts
TWILIO_TEST_NUMBER=
TWILIO_TEST_EMAIL=alerts-test@example.com

# ---------------------------------------------------------------------------
# EMAIL via SendGrid (optional — without a key, email is simulated)
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=
# Must be a verified SendGrid sender identity; falls back to TWILIO_TEST_EMAIL
SENDGRID_FROM_EMAIL=
# Default recipient for POST /refresh and POST /test-email
DEMO_RECIPIENT_EMAIL=

# Force dry-run even when fully configured
TEST_MODE=false

# ---------------------------------------------------------------------------
# SERVICE URLS (inter-service calls)
# ---------------------------------------------------------------------------
EXTRACTION_SERVICE_URL=http://localhost:8081
ASSESSMENT_SERVICE_URL=http://localhost:8082

# ---------------------------------------------------------------------------
# EXTRACTION (Part 1)
# ---------------------------------------------------------------------------
CELLAR_SPARQL_ENDPOINT=http://publications.europa.eu/webapi/rdf/sparql
# Used in the polite User-Agent
CONTACT_EMAIL=contact@example.com

# ---------------------------------------------------------------------------
# ASSESSMENT (Part 2)
# ---------------------------------------------------------------------------
# PARTNERS_PATH=dataset/partners.json

# ---------------------------------------------------------------------------
# GENERAL
# ---------------------------------------------------------------------------
# Request timeout in seconds (extraction default 60, assessment 120, alerting 180)
# HTTP_TIMEOUT=60
LOG_LEVEL=INFO
# Comma-separated frontend origins; "*" allows any (dev default)
CORS_ORIGINS=*
