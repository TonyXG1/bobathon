# ============================================================================
# DATABASE
# ============================================================================

# SQLite (default for development)
DATABASE_URL=sqlite:///./regulatory_radar.db

# PostgreSQL (for production or docker-compose)
# DATABASE_URL=postgresql://radar_user:changeme@localhost:5432/regulatory_radar

# ============================================================================
# TWILIO (SMS/WhatsApp/Email Alerts)
# ============================================================================

# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio phone number (from number)
TWILIO_PHONE_NUMBER=+1234567890

# YOUR test number/email (where alerts will be sent)
# NEVER use portfolio contacts from partners.json
TWILIO_TEST_NUMBER=+1234567890
TWILIO_TEST_EMAIL=your-test-email@example.com

# Twilio promo code for hackathon credit
# TWILIO_PROMO_CODE=TUM-TWILIO-50

# ============================================================================
# SERVICE URLS (for orchestrator and dashboard)
# ============================================================================

EXTRACTION_SERVICE_URL=http://localhost:8081
ASSESSMENT_SERVICE_URL=http://localhost:8082
ALERTING_SERVICE_URL=http://localhost:8083

# ============================================================================
# EXTERNAL APIs
# ============================================================================

# EUR-Lex / CELLAR
CELLAR_SPARQL_ENDPOINT=http://publications.europa.eu/webapi/rdf/sparql
CELLAR_REST_BASE_URL=https://eur-lex.europa.eu

# ECHA
ECHA_API_BASE_URL=https://chem.echa.europa.eu
ECHA_CANDIDATE_LIST_URL=https://echa.europa.eu/candidate-list-table

# ============================================================================
# RATE LIMITING & CACHING
# ============================================================================

# CELLAR SPARQL: max concurrent connections
CELLAR_MAX_CONCURRENT=5

# ECHA: cache TTL in seconds (24 hours = 86400)
ECHA_CACHE_TTL=86400

# HTTP request timeout in seconds
HTTP_TIMEOUT=30

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=text

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Enable debug mode (FastAPI reload, detailed errors)
DEBUG=true

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000,http://localhost:5173

# ============================================================================
# SECURITY
# ============================================================================

# Secret key for session management
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# API key for inter-service communication (optional)
# API_KEY=your-api-key-here

# ============================================================================
# ORCHESTRATOR
# ============================================================================

# Schedule for extraction job (cron format)
# "0 */6 * * *" = every 6 hours
EXTRACTION_SCHEDULE=0 */6 * * *

# Schedule for assessment job (cron format)
# "30 */6 * * *" = 30 min after extraction
ASSESSMENT_SCHEDULE=30 */6 * * *

# Enable automatic alerting after assessment
AUTO_ALERT=true

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable specific features
ENABLE_CELLAR_SPARQL=true
ENABLE_CELLAR_REST=true
ENABLE_ECHA_SCRAPING=true
ENABLE_RSS_FEEDS=true

# ============================================================================
# DEVELOPMENT / TESTING
# ============================================================================

# Use mock data instead of live sources (for testing)
USE_MOCK_DATA=false

# Skip external API calls (for offline development)
OFFLINE_MODE=false

# Test mode: don't actually send alerts
TEST_MODE=false

# ============================================================================
# DOCKER COMPOSE OVERRIDES
# ============================================================================

# These are used by docker-compose.yml
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=regulatory_radar
POSTGRES_USER=radar_user
POSTGRES_PASSWORD=changeme
