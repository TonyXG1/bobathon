{
  "$defs": {
    "RequirementScope": {
      "description": "Scope of a regulatory requirement.",
      "properties": {
        "categories": {
          "anyOf": [
            {
              "items": {
                "enum": [
                  "audio",
                  "battery_pack",
                  "camera",
                  "charging_equipment",
                  "computing",
                  "display",
                  "drone",
                  "emobility_battery",
                  "gaming",
                  "industrial_equipment",
                  "iot_sensor",
                  "led_lighting",
                  "medical_wearable",
                  "networking",
                  "smartphone",
                  "toy_electronic",
                  "wearable"
                ],
                "type": "string"
              },
              "type": "array"
            },
            {
              "const": "all",
              "type": "string"
            }
          ],
          "description": "Product categories in scope, or 'all' for all categories",
          "title": "Categories"
        },
        "substances": {
          "description": "Substances named in the requirement (empty if none)",
          "items": {
            "enum": [
              "lead",
              "cadmium",
              "mercury",
              "chromium_vi",
              "PBB",
              "PBDE",
              "DEHP",
              "BPA",
              "decaBDE",
              "TBBPA",
              "MCCP",
              "PFAS_PFHxA",
              "dioxane"
            ],
            "type": "string"
          },
          "title": "Substances",
          "type": "array"
        },
        "markets": {
          "description": "Markets where requirement applies (ISO country codes, 'EU' = all 27 states)",
          "items": {
            "type": "string"
          },
          "title": "Markets",
          "type": "array"
        },
        "conditions": {
          "default": "",
          "description": "Free-text conditions and carve-outs (e.g., 'LMT and industrial batteries only')",
          "title": "Conditions",
          "type": "string"
        }
      },
      "required": [
        "categories",
        "markets"
      ],
      "title": "RequirementScope",
      "type": "object"
    }
  },
  "description": "A regulatory requirement from a live source.\n\nOutput of Part 1 (extraction service), input of Part 2 (assessment service).",
  "properties": {
    "update_id": {
      "description": "Unique identifier for this requirement",
      "title": "Update Id",
      "type": "string"
    },
    "published_date": {
      "description": "When the requirement was published",
      "format": "date",
      "title": "Published Date",
      "type": "string"
    },
    "source": {
      "description": "Source name (e.g., 'EUR-Lex', 'ECHA')",
      "title": "Source",
      "type": "string"
    },
    "source_url": {
      "description": "Live portal URL where this requirement was read (MANDATORY)",
      "title": "Source Url",
      "type": "string"
    },
    "celex": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "CELEX number (for EUR-Lex documents)",
      "title": "Celex"
    },
    "consolidation_date": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Consolidation date of the act",
      "title": "Consolidation Date"
    },
    "access_timestamp": {
      "description": "When we fetched this requirement (UTC)",
      "format": "date-time",
      "title": "Access Timestamp",
      "type": "string"
    },
    "regulation_family": {
      "description": "Regulation family (from taxonomy.json)",
      "enum": [
        "rohs",
        "reach",
        "weee",
        "battery",
        "ppwr",
        "gpsr",
        "red",
        "espr",
        "toy_safety",
        "mdr",
        "pops",
        "epr",
        "epr_packaging",
        "energy_label",
        "emc",
        "lvd",
        "machinery",
        "atex",
        "chemical_safety",
        "cybersecurity",
        "other"
      ],
      "title": "Regulation Family",
      "type": "string"
    },
    "reference": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Legal reference (article/annex)",
      "title": "Reference"
    },
    "title": {
      "description": "Human-readable title",
      "title": "Title",
      "type": "string"
    },
    "summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Brief summary",
      "title": "Summary"
    },
    "change_type": {
      "description": "Type of change (new/amendment/correction)",
      "enum": [
        "new",
        "amendment",
        "correction"
      ],
      "title": "Change Type",
      "type": "string"
    },
    "effective_date": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "When the requirement becomes effective",
      "title": "Effective Date"
    },
    "deadline_date": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Compliance deadline",
      "title": "Deadline Date"
    },
    "severity": {
      "description": "Severity level (low/medium/high)",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "Severity",
      "type": "string"
    },
    "action_required": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "What action is required to comply",
      "title": "Action Required"
    },
    "scope": {
      "$ref": "#/$defs/RequirementScope",
      "description": "Scope of the requirement"
    },
    "corrects": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "If present, the update_id this entry duplicates/corrects (for de-duplication)",
      "title": "Corrects"
    }
  },
  "required": [
    "update_id",
    "published_date",
    "source",
    "source_url",
    "access_timestamp",
    "regulation_family",
    "title",
    "change_type",
    "severity",
    "scope"
  ],
  "title": "Requirement",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regulatory-radar.example.com/schemas/requirement.schema.json"
}